{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "lle-v2/journal-entry",
  "title": "JournalEntry",
  "type": "object",
  "required": ["id", "timestamp", "type", "coordinates_2d", "desert_value"],
  "additionalProperties": false,
  "properties": {
    "id":        { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "type": {
      "type": "string",
      "enum": ["probe_discovery","dig_site","voronoi","manual","fabrication_note","v1_import"]
    },
    "coordinates_2d": {
      "type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2,
      "description": "Position in 2D UMAP layout space. NOT 3D scene space."
    },
    "coordinates_highD": {
      "oneOf": [{"type": "array", "items": {"type": "number"}}, {"type": "null"}],
      "description": "Full high-dimensional embedding vector. Null for v1_import entries."
    },
    "desert_value":   { "type": "number", "minimum": 0.0 },
    "nearest_concepts": {
      "type": "array", "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["term", "distance"],
        "additionalProperties": false,
        "properties": {
          "term":             { "type": "string", "maxLength": 100 },
          "distance":         { "type": "number", "minimum": 0.0 },
          "roget_categories": { "oneOf": [{"type": "array", "items": {"type": "string"}}, {"type": "null"}] },
          "roget_class":      { "oneOf": [{"type": "string"}, {"type": "null"}] }
        }
      }
    },
    "roget_context": {
      "oneOf": [
        {
          "type": "object",
          "required": ["category_a", "category_b"],
          "additionalProperties": false,
          "properties": {
            "category_a": {"type": "string"},
            "category_b": {"type": "string"},
            "section_a":  {"oneOf": [{"type": "string"}, {"type": "null"}]},
            "section_b":  {"oneOf": [{"type": "string"}, {"type": "null"}]},
            "class_a":    {"oneOf": [{"type": "string"}, {"type": "null"}]},
            "class_b":    {"oneOf": [{"type": "string"}, {"type": "null"}]}
          }
        },
        {"type": "null"}
      ],
      "description": "Null for v1_import — Roget context cannot be backfilled."
    },
    "generated_description": { "oneOf": [{"type": "string", "maxLength": 1000}, {"type": "null"}] },
    "user_notes":             { "type": "string", "maxLength": 2000, "default": "" },
    "fabrication_notes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "material":   {"type": "string", "maxLength": 200},
        "method":     {"type": "string", "maxLength": 200},
        "dimensions": {"type": "string", "maxLength": 200},
        "status":     {"type": "string", "enum": ["idea","planned","in_progress","complete"]},
        "photos":     {"type": "array", "items": {"type": "string", "maxLength": 500}, "maxItems": 20}
      }
    },
    "tags":           { "type": "array", "items": {"type": "string", "maxLength": 50}, "maxItems": 20 },
    "starred":        { "type": "boolean", "default": false },
    "v1_source":      { "oneOf": [{"type": "object", "additionalProperties": true}, {"type": "null"}] },
    "schema_version": { "type": "integer" }
  }
}
